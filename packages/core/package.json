{
  "name": "agentsist",
  "version": "0.1.0",
  "type": "module",
  "description": "A production reliability runtime for AI agents",
  "author": "Bossadi Zenith <hello@bossadizenith.me>",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "reliability",
    "middleware",
    "retry",
    "typescript",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bossadizenith/agentsist"
  },
  "homepage": "https://github.com/bossadizenith/agentsist#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --watch",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ai": "^6.0.194",
    "@ai-sdk/provider": "^3.0.10"
  },
  "devDependencies": {
    "@agentsist/typescript-config": "workspace:*",
    "@agentsist/eslint-config": "workspace:*",
    "@ai-sdk/provider": "^3.0.10",
    "@types/bun": "latest",
    "ai": "^6.0.194",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "dotenv": "^17.4.2"
  }
}
