{
  "name": "agentruntime",
  "version": "0.0.1",
  "type": "module",
  "description": "A production reliability runtime for AI agents",
  "author": "Bossadi Zenith <hello@bossadizenith.me>",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "reliability",
    "middleware",
    "retry",
    "typescript",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bossadizenith/agentruntime"
  },
  "homepage": "https://github.com/bossadizenith/agentruntime#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --watch",
    "test": "bun test"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ai": "^6.0.194",
    "@ai-sdk/provider": "^3.0.10",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@agentruntime/typescript-config": "workspace:*",
    "@agentruntime/eslint-config": "workspace:*",
    "@types/bun": "latest",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "dotenv": "^17.4.2"
  }
